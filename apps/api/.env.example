DATABASE_URL=postgresql://user:password@localhost:5432/chatbot

# Alternative form (for better-sqlite3 compatibility)
POSTGRES_URL=postgresql://user:password@localhost:5432/chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chatbot

# Connection pooling settings
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_IDLE_TIMEOUT=30000

# SSL settings (set to 'true' for production with SSL)
POSTGRES_SSL=false

# Legacy SQLite path (for local development)
#DB_PATH=/home/ubuntu/kyro-chat/apps/api/data/chatbot.db

# ── E2B Sandbox Code Execution ──────────────────────────────────────────────
# E2B_API_KEY is required for secure cloud sandbox execution. The server will
# fail to start without it. Get your key at https://e2b.dev/docs/api-keys
E2B_API_KEY=
E2B_SANDBOX_TIMEOUT=60           # Sandbox timeout in seconds
E2B_MAX_CODE_LENGTH=10000        # Max code length in characters
#E2B_TEMPLATE_ID=                 # Optional custom sandbox template ID

# ── Sentry Error Tracking ──────────────────────────────────────────────────
# Set SENTRY_DSN to enable Sentry error tracking and performance monitoring.
# When not set, Sentry is disabled and all operations are no-ops.
# SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# SENTRY_SAMPLE_RATE=1.0
# SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_PROFILES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=1.0.0