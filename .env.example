# Kyro Chat — Environment Variables
# Copy to .env and fill in values

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=production

# Supabase (optional — runs without it)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# E2B Sandbox (optional)
E2B_API_KEY=

# Email (optional)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
