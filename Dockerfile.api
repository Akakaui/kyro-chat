FROM node:22-slim

WORKDIR /app

# Install build dependencies for better-sqlite3
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy package files
COPY apps/api/package.json ./

# Install dependencies
RUN npm install

# Copy source
COPY apps/api/ ./

# Create data directory
RUN mkdir -p /app/data

EXPOSE 3001

CMD ["npm", "start"]
